{
  "tenant_id_env": "MS365_TENANT_ID",
  "client_id_env": "MS365_CLIENT_ID",
  "client_secret_env": "MS365_CLIENT_SECRET",
  "mailbox_user": "your.name@yourcompany.com",
  "mail_folder": "Inbox",
  "rules": [
    {
      "name": "renewal-management-tool",
      "sender_contains": "reports@vendor.com",
      "subject_contains": "renewal management",
      "attachment_name_regex": "Renewal_Management_Tool.*\\.(xlsx|xlsm)$",
      "target_path": "Renewal_Management_Tool.xlsx",
      "overwrite": true,
      "latest_only": true
    },
    {
      "name": "portfolio-ops-source",
      "sender_contains": "ops@vendor.com",
      "subject_contains": "portfolio operations",
      "attachment_name_regex": ".*\\.(xlsx|csv)$",
      "download_dir": "tmp/email-reports",
      "overwrite": true,
      "latest_only": true
    }
  ],
  "post_update_commands": [
    [
      "python3",
      "{workspace}/tools/repair_excel_package_namespaces.py",
      "{workspace}/Renewal_Management_Tool.xlsx"
    ]
  ]
}
