<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>RISE Performance Platform</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;font-size:14px;color:#333;background:#f5f5f3;min-height:100vh}
.hidden{display:none!important}
button{cursor:pointer;font-family:inherit;font-size:13px}
input,select,textarea{font-family:inherit;font-size:13px;color:#333;background:#fff;border:0.5px solid #bbb;border-radius:8px;padding:8px 10px;width:100%;outline:none}
input:focus,select:focus,textarea:focus{border-color:#888;box-shadow:0 0 0 2px rgba(59,130,246,.15)}
label{font-size:12px;color:#666;display:block;margin-bottom:4px;font-weight:500}
.btn{padding:8px 16px;border-radius:8px;border:0.5px solid #bbb;background:#fff;color:#333;transition:background .15s;cursor:pointer}
.btn:hover{background:#f0f0ee}
.btn-primary{background:#1B3A4B;color:#fff;border-color:#1B3A4B}
.btn-primary:hover{background:#14303f}
.btn-danger{background:#8B0000;color:#fff;border-color:#8B0000}
.btn-danger:hover{background:#6d0000}
.btn-warn{background:#C9943C;color:#fff;border-color:#C9943C}
.btn-warn:hover{background:#b0832f}
.btn-sm{padding:5px 10px;font-size:12px}
.card{background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:16px 20px}
.badge{display:inline-block;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:500}
.badge-pip{background:#FDECEA;color:#8B0000}
.badge-coaching{background:#FFF8E1;color:#5D4037}
.badge-active{background:#EAF3DE;color:#27500A}
.badge-complete{background:#E6F1FB;color:#0C447C}
.badge-admin{background:#EEEDFE;color:#3C3489}
.badge-partial{background:#FFF8E1;color:#5D4037}
.badge-incomplete{background:#FDECEA;color:#8B0000}
.badge-overdue{background:#FDECEA;color:#8B0000}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.stat-card{background:#f5f5f3;border-radius:8px;padding:14px 16px}
.stat-label{font-size:12px;color:#666;margin-bottom:6px}
.stat-val{font-size:22px;font-weight:500}
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:12px;font-weight:500;color:#666;padding:8px 10px;border-bottom:0.5px solid #e0e0e0}
td{padding:9px 10px;border-bottom:0.5px solid #e0e0e0;font-size:13px;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafafa}
.nav{background:#fff;border-bottom:0.5px solid #e0e0e0;padding:0 16px;display:flex;align-items:center;gap:0;position:sticky;top:0;z-index:100;flex-wrap:wrap}
.nav-logo{font-size:14px;font-weight:500;color:#1B3A4B;padding:12px 0;margin-right:16px;border-right:0.5px solid #e0e0e0;padding-right:16px;white-space:nowrap}
.nav-accent{color:#C9943C}
.nav-tab{padding:12px 11px;font-size:12px;color:#666;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap}
.nav-tab.active{color:#1B3A4B;border-bottom-color:#1B3A4B;font-weight:500}
.nav-tab:hover:not(.active){color:#333;background:#f5f5f3}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:6px}
.page{padding:16px 20px;max-width:1300px;margin:0 auto}
.page-title{font-size:19px;font-weight:500;margin-bottom:3px}
.page-sub{font-size:13px;color:#666;margin-bottom:16px}
.section-title{font-size:14px;font-weight:500;margin-bottom:10px}
.form-row{display:grid;gap:10px}
.form-row.cols2{grid-template-columns:1fr 1fr}
.form-row.cols3{grid-template-columns:1fr 1fr 1fr}
.form-row.cols4{grid-template-columns:1fr 1fr 1fr 1fr}
.form-group{margin-bottom:10px}
.alert{padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:10px}
.alert-info{background:#E6F1FB;color:#0C447C;border:0.5px solid #B5D4F4}
.alert-danger{background:#FDECEA;color:#8B0000;border:0.5px solid #F7C1C1}
.alert-success{background:#EAF3DE;color:#27500A;border:0.5px solid #C0DD97}
.alert-warn{background:#FFF8E1;color:#5D4037;border:0.5px solid #FAC775}
.progress-bar-wrap{height:6px;background:#e8e8e8;border-radius:3px;overflow:hidden}
.progress-bar{height:6px;border-radius:3px}
.score-chip{display:inline-flex;align-items:center;justify-content:center;width:48px;height:22px;border-radius:20px;font-size:11px;font-weight:500}
.score-bad{background:#FDECEA;color:#8B0000}
.score-warn{background:#FFF8E1;color:#5D4037}
.score-ok{background:#EAF3DE;color:#1B5E20}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;z-index:1000}
.modal{background:#fff;border-radius:12px;padding:22px;width:700px;max-width:96vw;max-height:92vh;overflow-y:auto;border:0.5px solid #ccc}
.modal-wide{width:920px}
.modal-title{font-size:16px;font-weight:500;margin-bottom:3px}
.modal-sub{font-size:13px;color:#666;margin-bottom:14px}
.close-btn{background:none;border:none;font-size:18px;color:#888;cursor:pointer;float:right;line-height:1}
.tabs{display:flex;border-bottom:0.5px solid #e0e0e0;margin-bottom:14px;flex-wrap:wrap}
.tab{padding:8px 13px;font-size:13px;color:#666;border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap}
.tab.active{color:#333;border-bottom-color:#1B3A4B;font-weight:500}
.chip{padding:4px 10px;border-radius:20px;font-size:12px;background:#f5f5f3;border:0.5px solid #ddd;cursor:pointer;display:inline-block}
.chip.selected{background:#1B3A4B;color:#fff;border-color:#1B3A4B}
.file-drop{border:1.5px dashed #bbb;border-radius:10px;padding:24px;text-align:center;cursor:pointer;color:#888}
.file-drop:hover{background:#f5f5f3}
.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;background:#f5f5f3}
.login-card{background:#fff;border:0.5px solid #e0e0e0;border-radius:12px;padding:30px;width:380px}
.region-badge{display:inline-block;padding:2px 7px;border-radius:20px;font-size:11px;font-weight:500}
.r-west{background:#E1F5EE;color:#085041}
.r-east{background:#E6F1FB;color:#0C447C}
.r-student{background:#EEEDFE;color:#3C3489}
.r-admin{background:#FAEEDA;color:#633806}
.r-valdosta{background:#FDECEA;color:#8B0000}
.r-jax{background:#EAF3DE;color:#27500A}
.action-row{display:grid;grid-template-columns:32px 1fr 120px 120px 120px;gap:8px;align-items:start;padding:8px 0;border-bottom:0.5px solid #f0f0ee}
.action-row:last-child{border-bottom:none}
.status-btn{padding:3px 8px;border-radius:12px;font-size:11px;border:0.5px solid;cursor:pointer;white-space:nowrap}
.s-complete{background:#EAF3DE;color:#27500A;border-color:#C0DD97}
.s-partial{background:#FFF8E1;color:#5D4037;border-color:#FAC775}
.s-incomplete{background:#FDECEA;color:#8B0000;border-color:#F7C1C1}
.s-pending{background:#f5f5f3;color:#888;border-color:#ddd}
.meeting-row{display:grid;grid-template-columns:1fr 120px 100px 80px;gap:8px;align-items:center;padding:8px 0;border-bottom:0.5px solid #f0f0ee}
.meeting-row:last-child{border-bottom:none}
.combo-input{position:relative}
.combo-input input{width:100%}
.combo-dropdown{position:absolute;top:100%;left:0;right:0;background:#fff;border:0.5px solid #bbb;border-radius:0 0 8px 8px;z-index:50;max-height:160px;overflow-y:auto;display:none}
.combo-dropdown.open{display:block}
.combo-option{padding:7px 10px;cursor:pointer;font-size:13px}
.combo-option:hover{background:#f5f5f3}
a.inline-link{color:#1B3A4B;text-decoration:none;font-weight:500}
a.inline-link:hover{text-decoration:underline}
</style>
</head>
<body>
<div id="app"></div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
const REGIONS={
  west:{name:'West Coast / Central FL',short:'West/C.FL',cls:'r-west'},
  east:{name:'East Coast FL',short:'East FL',cls:'r-east'},
  student:{name:'Student Housing',short:'Student',cls:'r-student'},
  valdosta:{name:'Valdosta',short:'Valdosta',cls:'r-valdosta'},
  jax:{name:'JAX Corporate',short:'JAX',cls:'r-jax'}
};

const ROLE_OPTIONS=['Leasing Professional','Leasing Manager','Assistant Manager','Community Manager','Maintenance Technician','Maintenance Supervisor','Regional Manager','Administrative Assistant','Leasing Consultant','Property Manager'];
const COMMUNITY_OPTIONS=['RISE at Nocatee','RISE at Glen Kernan Park','RISE Viera','Pilots Pointe','The Preserve at Tech'];
const CUSTOM_MEETING_OPTION='__custom__';
const ADHOC_SCHEDULE_OPTION='__adhoc__';
const MEETING_TYPE_OPTIONS=[
  {value:'1:1',label:'1:1'},
  {value:'Initial presentation of PIP/Coaching plan',label:'Initial presentation of PIP/Coaching plan'},
  {value:'Weekly Follow Up',label:'Weekly Follow Up'},
  {value:'Task Completion Review',label:'Task Completion Review'},
  {value:CUSTOM_MEETING_OPTION,label:'Custom / one-off meeting'}
];

const DEFAULT_USERS=[
  {id:'admin',name:'Admin',pin:'0000',role:'admin',region:null},
  {id:'mgr_west',name:'West Manager',pin:'1111',role:'manager',region:'west'},
  {id:'mgr_east',name:'East Manager',pin:'2222',role:'manager',region:'east'},
  {id:'mgr_student1',name:'Student Manager 1',pin:'3333',role:'manager',region:'student'},
  {id:'mgr_student2',name:'Student Manager 2',pin:'4444',role:'manager',region:'student'},
  {id:'mgr_valdosta',name:'Valdosta Manager',pin:'5555',role:'manager',region:'valdosta'},
  {id:'mgr_jax',name:'JAX Manager',pin:'6666',role:'manager',region:'jax'},
];

let STATE={
  users:JSON.parse(localStorage.getItem('rise_users2')||JSON.stringify(DEFAULT_USERS)),
  employees:JSON.parse(localStorage.getItem('rise_employees2')||'[]'),
  plans:JSON.parse(localStorage.getItem('rise_plans2')||'[]'),
  currentUser:null,
  currentView:'dashboard',
};

function save(){
  localStorage.setItem('rise_users2',JSON.stringify(STATE.users));
  localStorage.setItem('rise_employees2',JSON.stringify(STATE.employees));
  localStorage.setItem('rise_plans2',JSON.stringify(STATE.plans));
}
function genId(){return Date.now().toString(36)+Math.random().toString(36).slice(2,6);}
function scoreClass(s){if(s===null||s===undefined)return '';s=parseFloat(s);if(s>=84)return 'score-ok';if(s>=65)return 'score-warn';return 'score-bad';}
function daysLeft(plan){return Math.ceil((new Date(plan.reviewDate)-new Date())/86400000);}
function pctComplete(plan){const s=new Date(plan.createdAt),e=new Date(plan.reviewDate),n=new Date();return Math.min(100,Math.max(0,Math.round(((n-s)/(e-s))*100)));}
function visiblePlans(){const u=STATE.currentUser;if(!u)return[];if(u.role==='admin')return STATE.plans;return STATE.plans.filter(p=>{const emp=STATE.employees.find(e=>e.id===p.employeeId);return emp&&emp.region===u.region;});}
function visibleEmployees(){const u=STATE.currentUser;if(!u)return[];if(u.role==='admin')return STATE.employees;return STATE.employees.filter(e=>e.region===u.region);}
function regionLabel(r){if(!r)return '<span class="region-badge r-admin">All Regions</span>';const reg=REGIONS[r];if(!reg)return r;return `<span class="region-badge ${reg.cls}">${reg.short}</span>`;}
function todayStr(){return new Date().toISOString().slice(0,10);}
function formatPlanStatus(status){
  if(status==='shop_ordered')return 'Shop Ordered';
  if(status==='completed')return 'Completed';
  if(status==='archived')return 'Archived';
  if(status==='active')return 'Active';
  return String(status||'').replace(/_/g,' ');
}
function getPlanStatusBadgeClass(status){
  if(status==='active')return 'badge-active';
  if(status==='shop_ordered')return 'badge-partial';
  if(status==='archived')return 'badge-admin';
  return 'badge-complete';
}
function isStandardMeetingType(type){return MEETING_TYPE_OPTIONS.some(opt=>opt.value===type&&opt.value!==CUSTOM_MEETING_OPTION);}
function renderMeetingTypeOptions(selected=''){
  const chosen=isStandardMeetingType(selected)?selected:CUSTOM_MEETING_OPTION;
  return MEETING_TYPE_OPTIONS.map(opt=>`<option value="${opt.value}" ${opt.value===chosen?'selected':''}>${opt.label}</option>`).join('');
}
function toggleMeetingCustomInput(selectId,wrapId){
  const wrap=document.getElementById(wrapId);
  const sel=document.getElementById(selectId);
  if(wrap&&sel)wrap.classList.toggle('hidden',sel.value!==CUSTOM_MEETING_OPTION);
}
function getSelectedMeetingType(selectId,customId){
  const selected=document.getElementById(selectId)?.value||'';
  if(selected===CUSTOM_MEETING_OPTION)return document.getElementById(customId)?.value.trim()||'One-off meeting';
  return selected||'1:1';
}
function parseMeetingRef(ref){
  const raw=String(ref);
  if(raw.startsWith('manual-'))return{kind:'manual',index:parseInt(raw.slice(7),10)};
  const idx=parseInt(raw,10);
  return{kind:'scheduled',index:Number.isFinite(idx)?idx:null};
}
function getMeetingArrayIndexBySchedIdx(plan,schedIdx){return(plan.meetings||[]).findIndex(m=>m.schedIdx===schedIdx);}
function getResolvedScheduleMeeting(plan,sched){
  const existing=(plan.meetings||[]).find(m=>m.schedIdx===sched.schedIdx);
  if(existing){
    const resolvedStatus=existing.status==='completed'?'completed':(sched.due<todayStr()?'past_due':(existing.status||'scheduled'));
    return{...sched,...existing,due:sched.due,dueDate:existing.dueDate||sched.due,heldDate:existing.heldDate||existing.date||'',label:existing.label||existing.type||sched.type,status:resolvedStatus};
  }
  return{...sched,dueDate:sched.due,heldDate:'',label:sched.type,status:sched.due<todayStr()?'past_due':'scheduled',notes:''};
}
function getResolvedSchedule(plan){return getSchedule(plan).map(s=>getResolvedScheduleMeeting(plan,s));}
function getManualMeetings(plan){return(plan.meetings||[]).map((m,actualIdx)=>({...m,actualIdx})).filter(m=>m.schedIdx===undefined);}
function getUpcomingMeetingsForPlan(plan){
  const scheduled=getResolvedSchedule(plan).filter(m=>m.status!=='completed'&&((m.dueDate||m.due||'')>=todayStr())).map(m=>({...m,sortDate:m.dueDate||m.due}));
  const manual=getManualMeetings(plan).filter(m=>m.status==='scheduled'&&((m.dueDate||m.date||m.heldDate||'')>=todayStr())).map(m=>({...m,label:m.label||m.type||'1:1',sortDate:m.dueDate||m.date||m.heldDate||''}));
  return[...scheduled,...manual].sort((a,b)=>(a.sortDate||'').localeCompare(b.sortDate||''));
}
function getNextRequiredMeeting(plan){return getResolvedSchedule(plan).find(m=>m.status!=='completed')||null;}
function renderScheduleOptions(plan,selectedSchedIdx){
  const opts=getResolvedSchedule(plan).filter(m=>m.status!=='completed'||m.schedIdx===selectedSchedIdx);
  return[`<option value="${ADHOC_SCHEDULE_OPTION}" ${selectedSchedIdx===null||selectedSchedIdx===undefined?'selected':''}>One-off / manual meeting</option>`,...opts.map(m=>`<option value="${m.schedIdx}" ${m.schedIdx===selectedSchedIdx?'selected':''}>${m.label||m.type} — due ${m.due}</option>`)].join('');
}
function syncWeeklyLogSchedule(planId){
  const plan=STATE.plans.find(p=>p.id===planId);
  if(!plan)return;
  const schedRef=document.getElementById('lw-sched-ref')?.value;
  if(!schedRef||schedRef===ADHOC_SCHEDULE_OPTION)return;
  const sched=getSchedule(plan).find(s=>s.schedIdx===parseInt(schedRef,10));
  if(!sched)return;
  const meetingType=document.getElementById('lw-meeting-type');
  const dueDate=document.getElementById('lw-due-date');
  if(meetingType){meetingType.value=sched.type;toggleMeetingCustomInput('lw-meeting-type','lw-custom-wrap');}
  if(dueDate)dueDate.value=sched.due;
}
function getRiseWordmarkSVG(){
  return `<svg viewBox="0 0 520 122" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="RISE">
    <rect width="520" height="122" fill="none"/>
    <g fill="#023046">
      <path d="M8 84V20h56c23 0 37 12 37 31 0 14-8 24-21 28l25 39H72L52 84H39v34H8zm31-26h22c11 0 18-6 18-16 0-11-7-16-18-16H39v32z"/>
      <path d="M262 106c-18 0-33-5-45-15l13-19c9 8 21 12 33 12 13 0 21-5 21-13 0-7-5-11-17-15l-19-6c-20-6-31-18-31-35 0-23 20-39 49-39 18 0 33 5 45 16l-13 19c-9-7-18-11-30-11-11 0-18 5-18 13 0 7 6 11 18 15l18 6c21 7 31 18 31 35 0 24-19 38-55 38z"/>
      <path d="M352 20h97v25h-66v18h59v24h-59v31h-31V20z"/>
    </g>
    <g transform="translate(135 12)">
      <rect x="28" y="0" width="33" height="96" fill="#023046"/>
      <rect x="0" y="0" width="28" height="96" fill="#549db8"/>
      <rect x="1" y="8" width="26" height="6" fill="#ffffff"/>
      <rect x="1" y="24" width="26" height="6" fill="#ffffff"/>
      <rect x="1" y="40" width="26" height="6" fill="#ffffff"/>
      <rect x="1" y="56" width="26" height="6" fill="#ffffff"/>
      <rect x="1" y="72" width="26" height="6" fill="#ffffff"/>
    </g>
    <line x1="8" y1="116" x2="512" y2="116" stroke="#549db8" stroke-width="4"/>
  </svg>`;
}

function getMissedMeetings(plan){
  if(!plan.presentedAt)return 0;
  let missed=getResolvedSchedule(plan).filter(m=>m.status==='past_due').length;
  if(plan.meetings)missed+=plan.meetings.filter(m=>m.schedIdx===undefined&&m.status==='past_due').length;
  return missed;
}
function getOverdueActionItems(plan){
  if(!plan.weeklyUpdates)return 0;
  let count=0;
  plan.weeklyUpdates.forEach(w=>{
    if(w.items)w.items.forEach(a=>{if(a.status==='incomplete')count++;});
  });
  return count;
}
function getPlanAlerts(plan){
  const alerts=[];
  const dl=daysLeft(plan);
  if(dl<0&&plan.status==='active')alerts.push({type:'overdue',msg:'Review date passed'});
  if(!plan.presentedAt&&plan.status==='active')alerts.push({type:'presentation',msg:'Plan not yet presented to employee'});
  const missed=getMissedMeetings(plan);
  if(missed>0)alerts.push({type:'meeting',msg:`${missed} missed meeting${missed>1?'s':''}`});
  if(plan.presentedAt&&!plan.signedDocData&&plan.status==='active')alerts.push({type:'signed',msg:'Signed plan document missing'});
  const overdueItems=getOverdueActionItems(plan);
  if(overdueItems>0)alerts.push({type:'items',msg:`${overdueItems} incomplete action item${overdueItems>1?'s':''}`});
  return alerts;
}
function getTotalOverdueCount(){
  return visiblePlans().filter(p=>p.status==='active').reduce((acc,p)=>acc+(getPlanAlerts(p).length>0?1:0),0);
}

function render(){
  const app=document.getElementById('app');
  if(!STATE.currentUser){app.innerHTML=renderLogin();return;}
  app.innerHTML=renderShell();
  renderView();
}
function renderLogin(){
  return `<div class="login-wrap"><div class="login-card">
    <div style="font-size:22px;font-weight:500;color:#1B3A4B;margin-bottom:3px">RISE <span style="color:#C9943C">Residential</span></div>
    <div style="font-size:13px;color:#888;margin-bottom:22px">Leasing Performance Platform</div>
    <div class="form-group"><label>Username</label><input id="li-user" placeholder="Enter username"></div>
    <div class="form-group"><label>PIN</label><input id="li-pin" type="password" placeholder="Enter PIN" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <div id="li-err" class="alert alert-danger hidden">Invalid username or PIN.</div>
    <button class="btn btn-primary" style="width:100%;margin-top:4px" onclick="doLogin()">Sign In</button>
    <div style="margin-top:14px;padding-top:14px;border-top:0.5px solid #eee;font-size:11px;color:#aaa">
      Defaults: admin/0000 · west/1111 · east/2222 · student1/3333 · student2/4444 · valdosta/5555 · jax/6666
    </div>
  </div></div>`;
}
function doLogin(){
  const u=document.getElementById('li-user').value.trim().toLowerCase();
  const p=document.getElementById('li-pin').value.trim();
  const match=STATE.users.find(x=>x.id===u||x.name.toLowerCase()===u||x.name.toLowerCase().replace(/\s+/g,'_')===u.replace(/\s+/g,'_'));
  if(match&&match.pin===p){STATE.currentUser=match;STATE.currentView='dashboard';render();}
  else{document.getElementById('li-err').classList.remove('hidden');}
}
function renderShell(){
  const u=STATE.currentUser;
  const tabs=[
    {id:'dashboard',label:'Dashboard'},
    {id:'plans',label:'Active Plans'},
    {id:'newplan',label:'+ New Plan'},
    {id:'weekly',label:'Weekly Updates'},
    {id:'employees',label:'Employees'},
    {id:'export',label:'Weekly Export'},
    ...(u.role==='admin'?[{id:'settings',label:'Settings'}]:[]),
  ];
  return `<div class="nav">
    <div class="nav-logo">RISE <span class="nav-accent">Performance</span></div>
    ${tabs.map(t=>`<div class="nav-tab ${STATE.currentView===t.id?'active':''}" onclick="switchView('${t.id}')">${t.label}</div>`).join('')}
    <div class="nav-right">
      ${u.role==='admin'?'<span class="badge badge-admin">Admin</span>':regionLabel(u.region)}
      <span style="font-size:12px;color:#888">${u.name}</span>
      <button class="btn btn-sm" onclick="logout()">Sign out</button>
    </div>
  </div>
  <div id="view-container"></div>
  <div id="modal-container"></div>`;
}
function switchView(v){STATE.currentView=v;render();}
function logout(){STATE.currentUser=null;render();}
function renderView(){
  const c=document.getElementById('view-container');if(!c)return;
  switch(STATE.currentView){
    case 'dashboard':c.innerHTML=renderDashboard();break;
    case 'plans':c.innerHTML=renderPlans();break;
    case 'newplan':c.innerHTML=renderNewPlan();break;
    case 'weekly':c.innerHTML=renderWeeklyUpdates();break;
    case 'employees':c.innerHTML=renderEmployees();break;
    case 'export':c.innerHTML=renderExport();break;
    case 'settings':c.innerHTML=renderSettings();break;
    default:c.innerHTML=renderDashboard();
  }
}

function renderDashboard(){
  const plans=visiblePlans();
  const active=plans.filter(p=>p.status==='active');
