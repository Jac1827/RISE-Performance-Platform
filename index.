function parsePastedPlanText(){
  const text=document.getElementById('paste-plan-text').value.trim();
  if(!text){alert('Please paste some plan text first.');return;}
  const items=[];
  const lines=text.split('\n');
  let currentArea='General';
  const areaPatterns=[/telephone.*needs/i,/telephone.*contact/i,/telephone.*appoint/i,/on.site.*greet/i,/on.site.*clos/i,/on.site.*tour/i,/closing/i,/greeting/i,/demonstrat/i,/follow.up/i];
  const areaNames=['Telephone — Needs Assessment','Telephone — Contact Capture','Telephone — Appointment Setting','On-Site — Greeting & Introduction','On-Site — Closing & Commitment','On-Site — Tour Content','Closing','Greeting','Demonstrating','Follow-Up'];
  lines.forEach(line=>{
    for(let i=0;i<areaPatterns.length;i++){if(areaPatterns[i].test(line)&&line.length<80){currentArea=areaNames[i];return;}}
    const m=line.match(/^\s*(\d+)[.)]\s+(.{10,})/);
    if(m)items.push({text:m[2].trim(),area:currentArea});
  });
  if(items.length===0){
    document.getElementById('plan-extract-status').innerHTML='<div class="alert alert-warn">No numbered items detected. Try the JSON paste option or add items manually.</div>';
    closeModal();return;
  }
  _extractedActionItems=items;
  showExtractedPreview();
  closeModal();
}

