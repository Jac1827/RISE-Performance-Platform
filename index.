function handleRosterUpload(event){
  const file=event.target.files[0];if(!file)return;
  const status=document.getElementById('roster-status');
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const wb=XLSX.read(e.target.result,{type:'binary'});
      const ws=wb.Sheets[wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{header:1});
      const headers=rows[0].map(h=>String(h).toLowerCase().trim());
      const nI=headers.findIndex(h=>h.includes('name'));
      const cI=headers.findIndex(h=>h.includes('community'));
      const rI=headers.findIndex(h=>h.includes('role')||h.includes('title'));
      const rgI=headers.findIndex(h=>h.includes('region'));
      let added=0;
      for(let i=1;i<rows.length;i++){
        const row=rows[i];if(!row[nI])continue;
        const rRaw=(rgI>=0?String(row[rgI]||''):'').toLowerCase();
        let region='';
        if(rRaw.includes('west')||rRaw.includes('central'))region='west';
        else if(rRaw.includes('east'))region='east';
        else if(rRaw.includes('student'))region='student';
        else if(rRaw.includes('valdosta'))region='valdosta';
        else if(rRaw.includes('jax'))region='jax';
        STATE.employees.push({id:genId(),name:String(row[nI]),role:rI>=0?String(row[rI]||''):'Leasing Professional',community:cI>=0?String(row[cI]||''):'',region});
        added++;
      }
      save();status.innerHTML=`<div class="alert alert-success">${added} employees imported.</div>`;renderView();
    }catch(err){status.innerHTML=`<div class="alert alert-danger">Upload error: ${err.message}</div>`;}
  };
  reader.readAsBinaryString(file);
}
