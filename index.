function saveWeeklyLog(planId,initialSchedIdx=null){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan)return;
  const items=plan.actionItems||[];
  if(!plan.weeklyUpdates)plan.weeklyUpdates=[];
  if(!plan.meetings)plan.meetings=[];
  const schedRef=document.getElementById('lw-sched-ref')?.value||ADHOC_SCHEDULE_OPTION;
  const schedIdx=schedRef!==ADHOC_SCHEDULE_OPTION?parseInt(schedRef,10):initialSchedIdx;
  const meetingType=getSelectedMeetingType('lw-meeting-type','lw-custom-type');
  const heldDate=document.getElementById('lw-date').value;
  const dueDate=document.getElementById('lw-due-date').value||heldDate;
  const meetingStatus=document.getElementById('lw-meeting-status').value;
  const meetingEntry={type:meetingType,label:meetingType,dueDate,heldDate,date:heldDate,status:meetingStatus,notes:document.getElementById('lw-notes').value};
  if(schedRef!==ADHOC_SCHEDULE_OPTION&&Number.isFinite(schedIdx)){
    meetingEntry.schedIdx=schedIdx;
    const existingIdx=getMeetingArrayIndexBySchedIdx(plan,schedIdx);
    if(existingIdx>=0)plan.meetings[existingIdx]={...plan.meetings[existingIdx],...meetingEntry};
    else plan.meetings.push(meetingEntry);
  }else{
    plan.meetings.push(meetingEntry);
  }
  const logItems=items.map((_,i)=>({
    idx:i,
    status:document.getElementById(`lw-s-${i}`)?.value||'incomplete',
    note:document.getElementById(`lw-n-${i}`)?.value||''
  }));
  plan.weeklyUpdates.push({
    date:heldDate,
    meetingType,
    meetingStatus,
    meetingDueDate:dueDate,
    meetingSchedIdx:schedRef!==ADHOC_SCHEDULE_OPTION&&Number.isFinite(schedIdx)?schedIdx:null,
    overallStatus:document.getElementById('lw-overall').value,
    notes:document.getElementById('lw-notes').value,
    items:logItems
  });
  save();closeModal();
  window._weeklyPlanId=planId;
  STATE.currentView='weekly';
  render();
}

