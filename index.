        <thead><tr><th>Area</th><th>Benchmark</th><th>Current</th><th>Required Actions (All Must Be Completed)</th></tr></thead>
        <tbody>
          ${groupedItems.map(group=>`<tr><td>${escapeHTML(group.area)}</td><td>84%</td><td>${formatPercentDisplay(getAreaCurrentScore(p,group.area))}</td><td><ul>${group.texts.map(text=>`<li>${escapeHTML(text)}</li>`).join('')}</ul></td></tr>`).join('')}
        </tbody>
      </table>`:'<p class="muted">No action items have been loaded for this plan yet.</p>'}
    </div>

    <div class="section">
      <div class="section-title">Section V — Management Support & Oversight Commitments</div>
      <p>RISE Residential will provide the following support during the review period to reinforce expectations and document progress.</p>
      <ul>${supportBullets.map(item=>`<li>${escapeHTML(item)}</li>`).join('')}</ul>
    </div>

    <div class="section">
      <div class="section-title">Section VI — ${p.type==='pip'?'Consequences of Non-Compliance':'Accountability & Next Steps'}</div>
      <p>${getConsequenceCopy(p)}</p>
      ${p.type==='pip'&&p.consequences?`<ul>
        <li>Extension of the performance improvement period with escalated expectations.</li>
        <li>Additional formal disciplinary action.</li>
        <li>Change in duties, reassignment, or termination of employment if improvement is not achieved.</li>
      </ul>`:''}
    </div>

    <div class="section">
      <div class="section-title">Section VII — Acknowledgment & Signatures</div>
      <p>By signing below, the parties acknowledge receipt of this document, review of the expectations outlined above, and understanding of the accountability standards for the review period. Employee signature confirms receipt and awareness of the plan's terms.</p>
      <div class="sig-grid">
        <div class="sig-block"><div class="sig-name">Employee — ${emp?escapeHTML(emp.name):''}</div><div class="sig-line"><span>Signature</span><span>Date</span></div></div>
        <div class="sig-block"><div class="sig-name">Direct Manager</div><div class="sig-line"><span>Signature</span><span>Date</span></div></div>
        <div class="sig-block"><div class="sig-name">HR Representative / People Operations</div><div class="sig-line"><span>Signature</span><span>Date</span></div></div>
        <div class="sig-block"><div class="sig-name">VP of Property Management (if applicable)</div><div class="sig-line"><span>Signature</span><span>Date</span></div></div>
      </div>
    </div>

    ${meetings.length||updates.length?`<div class="section">
      <div class="section-title">Appendix — Progress Tracking</div>
      ${meetings.length?`<table class="appendix-table" style="margin-bottom:12px">
        <thead><tr><th>Meeting</th><th>Date</th><th>Status</th></tr></thead>
        <tbody>${meetings.map((m,i)=>`<tr><td>${escapeHTML(m.label||'Week '+(i+1))}</td><td>${escapeHTML(m.date||m.heldDate||'—')}</td><td>${escapeHTML(m.status==='completed'?'Completed':m.status==='past_due'?'Past due':'Scheduled')}</td></tr>`).join('')}</tbody>
      </table>`:''}
      ${updates.length?`<table class="appendix-table">
        <thead><tr><th>Week</th><th>Date</th><th>Overall Status</th><th>Manager Notes</th></tr></thead>
        <tbody>${updates.map((u,i)=>`<tr><td>Week ${i+1}</td><td>${escapeHTML(u.date||'—')}</td><td>${escapeHTML(u.overallStatus||'—')}</td><td>${u.notes?escapeHTML(u.notes).replace(/\n/g,'<br>'):'—'}</td></tr>`).join('')}</tbody>
      </table>`:''}
    </div>`:''}

    <div class="footer-note">This ${p.type==='pip'?'Performance Improvement Plan':'coaching action plan'} was prepared in accordance with RISE Residential Management employment policies and procedures. Questions regarding this document should be directed to Human Resources.</div>
    <button class="print-btn" onclick="window.print()">Print / Save as PDF</button>
  </div>
  </body></html>`);
  w.document.close();
  closeModal();
}

function exportExcel(planId){
  const p=STATE.plans.find(x=>x.id===planId);
  const emp=STATE.employees.find(e=>e.id===p.employeeId);
  const wb=XLSX.utils.book_new();
  const summary=[['RISE Residential — '+p.type.toUpperCase()],[],['Employee',emp?emp.name:'—'],['Community',emp?emp.community||'—':'—'],['Region',emp?REGIONS[emp.region]?.name||'—':'—'],['Shop Date',p.shopDate||'—'],['Issued',p.createdAt],['Review Date',p.reviewDate],['Manager',p.manager||'—'],[],['SCORES','Actual','Benchmark','Status'],['Telephone Total',p.telScore!=null?p.telScore+'%':'—','84%',p.telScore!=null&&p.telScore>=84?'MET':'NOT MET'],['On-Site Total',p.onsiteScore!=null?p.onsiteScore+'%':'—','84%',p.onsiteScore!=null&&p.onsiteScore>=84?'MET':'NOT MET'],['Overall',p.overallScore!=null?p.overallScore+'%':'—','84%',p.overallScore!=null&&p.overallScore>=84?'MET':'NOT MET'],[],[' Notes',p.notes||'—']];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(summary),'Plan Summary');
  if(p.actionItems&&p.actionItems.length){
    const aiData=[['#','Area','Action Item'],...p.actionItems.map((it,i)=>[i+1,it.area||'—',it.text])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(aiData),'Action Items');
  }
  if(p.weeklyUpdates&&p.weeklyUpdates.length){
    const wData=[['Week','Date','Overall Status','Notes','Items Complete','Items Partial','Items Incomplete'],...p.weeklyUpdates.map((w,i)=>[i+1,w.date||'—',w.overallStatus||'—',w.notes||'—',(w.items||[]).filter(x=>x.status==='complete').length,(w.items||[]).filter(x=>x.status==='partial').length,(w.items||[]).filter(x=>x.status==='incomplete').length])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(wData),'Weekly Updates');
  }
  if(p.meetings&&p.meetings.length){
    const mData=[['Meeting','Date','Status'],...p.meetings.map((m,i)=>[m.label||'Week '+(i+1),m.date||m.heldDate||'—',m.status])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(mData),'Meetings');
  }
  XLSX.writeFile(wb,`RISE_${p.type.toUpperCase()}_${emp?emp.name.replace(/\s+/g,'_'):'emp'}_${p.createdAt}.xlsx`);closeModal();
}

function exportCSVSingle(planId){
  const p=STATE.plans.find(x=>x.id===planId);
  const emp=STATE.employees.find(e=>e.id===p.employeeId);
  const meetings=p.meetings||[];
  const updates=p.weeklyUpdates||[];
  const lastW=updates[updates.length-1];
  const allItems=(lastW&&lastW.items)||[];
  const rows=[['Employee','Community','Region','Type','Shop Date','Overall','Telephone','On-Site','Review Date','Status','Manager','Meetings Done','Meetings Missed','Items Complete','Items Partial','Items Incomplete'],
    [emp?emp.name:'',emp?emp.community||'':'',emp?REGIONS[emp.region]?.name||'':'',p.type,p.shopDate||'',p.overallScore||'',p.telScore||'',p.onsiteScore||'',p.reviewDate,formatPlanStatus(p.status),p.manager||'',meetings.filter(m=>m.status==='completed').length,meetings.filter(m=>m.status==='past_due').length,allItems.filter(x=>x.status==='complete').length,allItems.filter(x=>x.status==='partial').length,allItems.filter(x=>x.status==='incomplete').length]];
  const csv=rows.map(r=>r.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')).join('\n');
  const a=document.createElement('a');a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);a.download=`RISE_plan_${emp?emp.name.replace(/\s+/g,'_'):'emp'}.csv`;a.click();closeModal();
}

function renderSettings(){
  return `<div class="page">
    <div class="page-title">Settings</div>
    <div class="page-sub">Manage manager logins and access levels. Admin only.</div>
    <div class="card" style="max-width:680px">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
        <div class="section-title" style="margin-bottom:0">Manager accounts</div>
        <button class="btn btn-primary btn-sm" onclick="openAddUser()">+ Add user</button>
      </div>
      <table>
        <thead><tr><th>Name</th><th>ID</th><th>Role</th><th>Region</th><th>PIN</th><th></th></tr></thead>
        <tbody>
        ${STATE.users.map(u=>`<tr>
          <td style="font-weight:500">${u.name}</td>
          <td style="font-size:12px;color:#888">${u.id}</td>
          <td><span class="badge ${u.role==='admin'?'badge-admin':'badge-active'}">${u.role}</span></td>
          <td>${u.region?regionLabel(u.region):'<span style="color:#888;font-size:12px">All</span>'}</td>
          <td style="font-family:monospace">••••</td>
          <td style="display:flex;gap:4px">
            <button class="btn btn-sm" onclick="openEditUser('${u.id}')">Edit</button>
            ${u.id!=='admin'?`<button class="btn btn-sm btn-danger" onclick="removeUser('${u.id}')">Remove</button>`:''}
          </td>
        </tr>`).join('')}
        </tbody>
      </table>
    </div>
  </div>`;
}
function openAddUser(){
  const mc=document.getElementById('modal-container');
  mc.innerHTML=`<div class="modal-overlay" onclick="if(event.target===this)closeModal()"><div class="modal" style="width:420px">
    <button class="close-btn" onclick="closeModal()">×</button>
    <div class="modal-title">Add user</div>
    <div class="form-group" style="margin-top:12px"><label>Full name</label><input id="nu-name"></div>
    <div class="form-group"><label>Username / ID</label><input id="nu-id" placeholder="e.g. mgr_west2"></div>
    <div class="form-group"><label>PIN</label><input id="nu-pin" type="password" maxlength="8"></div>
    <div class="form-group"><label>Role</label><select id="nu-role"><option value="manager">Manager</option><option value="admin">Admin</option></select></div>
    <div class="form-group"><label>Region</label><select id="nu-region">
      <option value="">All (admin)</option>
      ${Object.entries(REGIONS).map(([k,r])=>`<option value="${k}">${r.name}</option>`).join('')}
    </select></div>
    <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:10px">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveNewUser()">Add user</button>
    </div>
  </div></div>`;
}
function saveNewUser(){
  const id=document.getElementById('nu-id').value.trim().replace(/\s+/g,'_').toLowerCase();
  const name=document.getElementById('nu-name').value.trim();
  const pin=document.getElementById('nu-pin').value.trim();
  if(!id||!name||!pin){alert('All fields required.');return;}
  if(STATE.users.find(u=>u.id===id)){alert('ID already exists.');return;}
  STATE.users.push({id,name,pin,role:document.getElementById('nu-role').value,region:document.getElementById('nu-region').value||null});
  save();closeModal();renderView();
}
function openEditUser(uid){
  const u=STATE.users.find(x=>x.id===uid);if(!u)return;
  const mc=document.getElementById('modal-container');
  mc.innerHTML=`<div class="modal-overlay" onclick="if(event.target===this)closeModal()"><div class="modal" style="width:420px">
    <button class="close-btn" onclick="closeModal()">×</button>
    <div class="modal-title">Edit — ${u.name}</div>
    <div class="form-group" style="margin-top:12px"><label>Full name</label><input id="eu-name" value="${u.name}"></div>
    <div class="form-group"><label>New PIN (blank = keep current)</label><input id="eu-pin" type="password" maxlength="8"></div>
    <div class="form-group"><label>Role</label><select id="eu-role"><option value="manager" ${u.role==='manager'?'selected':''}>Manager</option><option value="admin" ${u.role==='admin'?'selected':''}>Admin</option></select></div>
    <div class="form-group"><label>Region</label><select id="eu-region">
      <option value="" ${!u.region?'selected':''}>All (admin)</option>
      ${Object.entries(REGIONS).map(([k,r])=>`<option value="${k}" ${u.region===k?'selected':''}>${r.name}</option>`).join('')}
    </select></div>
    <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:10px">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-primary" onclick="saveEditUser('${uid}')">Save</button>
    </div>
  </div></div>`;
}
function saveEditUser(uid){
  const u=STATE.users.find(x=>x.id===uid);if(!u)return;
  u.name=document.getElementById('eu-name').value.trim()||u.name;
  const np=document.getElementById('eu-pin').value.trim();if(np)u.pin=np;
  u.role=document.getElementById('eu-role').value;
  u.region=document.getElementById('eu-region').value||null;
  save();closeModal();renderView();
}
function removeUser(uid){if(!confirm('Remove this user?'))return;STATE.users=STATE.users.filter(u=>u.id!==uid);save();renderView();}

render();
</script>
