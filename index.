function escapeHTML(value){
  return String(value??'').replace(/[&<>"']/g,ch=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}
function formatDocDate(value){
  if(!value)return '________________________________';
  const d=new Date(`${value}T12:00:00`);
  if(Number.isNaN(d.getTime()))return value;
  return d.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'});
}
function formatPercentDisplay(value){
  if(value===null||value===undefined||value==='')return '—';
  const num=Math.round(Number(value)*10)/10;
  if(Number.isNaN(num))return `${value}%`;
  return `${String(num).replace(/\.0$/,'')}%`;
}
function formatVarianceDisplay(value,benchmark=84){
  if(value===null||value===undefined||value==='')return '—';
  const num=Math.round(Number(value)*10)/10;
  if(Number.isNaN(num))return '—';
  const diff=Math.round((num-benchmark)*10)/10;
  return `${diff>0?'+':''}${String(diff).replace(/\.0$/,'')} pts | ${num>=benchmark?'MET':'NOT MET'}`;
}
function getReviewPeriodText(plan){
  const days=parseInt(plan.timeline,10);
  return Number.isFinite(days)?`${days} days from date of issuance`:'Until next shop result';
}
function getPlanStatusLabel(plan){
  if(plan.status==='shop_ordered')return 'Shop Ordered';
  if(plan.status==='completed')return 'Completed';
  if(plan.status==='archived')return 'Archived';
  return plan.type==='pip'?'Active — Mandatory Participation Required':'Active — Coaching Participation Required';
}
function groupActionItemsByArea(items=[]){
  const grouped=new Map();
  items.forEach(item=>{
    const area=(item.area||'General').trim()||'General';
    if(!grouped.has(area))grouped.set(area,[]);
    grouped.get(area).push(item.text);
  });
  return Array.from(grouped.entries()).map(([area,texts])=>({area,texts}));
}
function getAreaCurrentScore(plan,area){
  const label=(area||'').toLowerCase();
  if(label.includes('telephone'))return plan.telScore;
  if(label.includes('on-site')||label.includes('on site'))return plan.onsiteScore;
  if(label.includes('follow-up'))return plan.followupScore;
  if(label.includes('closing'))return plan.closingScore;
  if(label.includes('demonstrating'))return plan.demoScore;
  if(label.includes('greeting'))return plan.greetScore;
  if(label.includes('identifying needs')||label.includes('needs'))return plan.needsScore;
  return plan.overallScore;
}
function getPerformanceStandardRows(plan){
  return [
    {label:'Telephone Score',value:plan.telScore},
    {label:'On-Site Score',value:plan.onsiteScore},
    {label:'Overall Combined Score',value:plan.overallScore}
  ].filter(row=>row.value!==null&&row.value!==undefined);
}
function getDeficiencyBullets(plan){
  const bullets=[];
  if(plan.telScore!=null&&plan.telScore<84)bullets.push(`Telephone performance is below the 84% benchmark at ${formatPercentDisplay(plan.telScore)} and requires immediate improvement in needs assessment, contact capture, and appointment setting.`);
  if(plan.onsiteScore!=null&&plan.onsiteScore<84)bullets.push(`On-site performance is below the 84% benchmark at ${formatPercentDisplay(plan.onsiteScore)} and requires improvement in greeting, tour control, closing, and next-step commitment.`);
  if(plan.greetScore!=null&&plan.greetScore<84)bullets.push(`Greeting behaviors scored ${formatPercentDisplay(plan.greetScore)}, indicating inconsistent introduction, rapport-setting, or prospect welcome standards.`);
  if(plan.needsScore!=null&&plan.needsScore<84)bullets.push(`Needs discovery scored ${formatPercentDisplay(plan.needsScore)}, indicating additional coaching is needed around qualifying questions and tailoring the presentation.`);
  if(plan.closingScore!=null&&plan.closingScore<84)bullets.push(`Closing behaviors scored ${formatPercentDisplay(plan.closingScore)}, reflecting missed opportunities to secure commitment and confirm next steps.`);
  if(plan.notes)bullets.push(escapeHTML(plan.notes).replace(/\n/g,'<br>'));
  if(!bullets.length)bullets.push('Current performance results and manager observations should continue to be monitored throughout the review period.');
  return bullets;
}
function getSupportCommitments(plan,employeeName){
  const name=employeeName||'the employee';
  const commitments=[
    `Weekly one-on-one check-in meetings between ${name} and the direct manager to review progress against plan objectives.`,
    'Written progress updates documenting completed actions, coaching feedback, and any remaining performance gaps.',
    'Access to applicable RISE training materials, scripts, performance guides, and coaching resources related to the documented deficiencies.'
  ];
  if((plan.actionItems||[]).some(item=>/role-plays?|tour|script/i.test(item.text)))commitments.push('Observed practice sessions and manager feedback to reinforce required behaviors, scripting, and closing standards.');
  if((plan.actionItems||[]).length)commitments.push(`Review of ${plan.actionItems.length} required action item${plan.actionItems.length===1?'':'s'} during the plan period, with coaching adjustments as needed.`);
  if(parseInt(plan.timeline,10)>=30)commitments.push('A mid-point review may be scheduled before the final review date to assess progress and adjust support as needed.');
  return commitments;
}
function getConsequenceCopy(plan){
  const reviewDate=formatDocDate(plan.reviewDate);
  if(plan.type==='pip'&&plan.consequences){
    return 'Failure to meet the measurable objectives outlined in this plan, or failure to participate fully in required coaching and oversight activities, may result in further disciplinary action up to and including termination of employment.';
  }
  if(plan.type==='pip'){
    return `Sustained improvement is required by ${reviewDate}. Failure to demonstrate timely progress may result in additional corrective action.`;
  }
  return `This coaching plan requires timely follow-through and sustained improvement by ${reviewDate}. If performance does not improve, management may escalate to formal corrective action.`;
}

