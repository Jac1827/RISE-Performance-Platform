function exportWeeklyExcel(){
  const plans=visiblePlans().filter(p=>p.status==='active');
  const wb=XLSX.utils.book_new();
  const header=['Employee','Community','Region','Type','Shop Date','Overall%','Tel%','On-Site%','Progress%','Days Left','Plan Start (Presented)','Review Date','Manager','Presented to Employee','Signed Doc Uploaded','Signed Doc Name','Scheduled Meetings Total','Meetings Completed','Meetings Missed','Next Meeting Due','Next Meeting Type','Last Logged Meeting Type','Action Items Complete','Action Items Partial','Action Items Incomplete','Last Update Date','Last Week Status','Consequences','Notes'];
  const rows=plans.map(p=>{
    const emp=STATE.employees.find(e=>e.id===p.employeeId);
    const meetings=p.meetings||[];
    const updates=p.weeklyUpdates||[];
    const lastW=updates[updates.length-1];
    const allItems=(lastW&&lastW.items)||[];
    const sched=getSchedule(p);
    const nextDueItem=getNextRequiredMeeting(p);
    return[
      emp?emp.name:'',emp?emp.community||'':'',emp?REGIONS[emp.region]?.name||'':'',
      p.type.toUpperCase(),p.shopDate||'',p.overallScore||'',p.telScore||'',p.onsiteScore||'',
      pctComplete(p),daysLeft(p),p.presentedAt||'Not set',p.reviewDate,p.manager||'',
      p.presentedAt?'Yes':'No',
      p.signedDocData?'Yes':'No',
      p.signedDocName||'',
      sched.length,
      meetings.filter(m=>m.status==='completed').length,
      getMissedMeetings(p),
      nextDueItem?nextDueItem.due:'',
      nextDueItem?(nextDueItem.label||nextDueItem.type):'',
      lastW?lastW.meetingType||'':'',
      allItems.filter(x=>x.status==='complete').length,
      allItems.filter(x=>x.status==='partial').length,
      allItems.filter(x=>x.status==='incomplete').length,
      lastW?lastW.date||'':'',lastW?lastW.overallStatus||'':'',
      p.consequences?'Yes':'No',p.notes||''
    ];
  });
  const ws=XLSX.utils.aoa_to_sheet([header,...rows]);
  XLSX.utils.book_append_sheet(wb,ws,'Weekly Status');
  const aiHeader=['Employee','Plan Type','Item #','Area','Action Item','Last Status','Last Note'];
  const aiRows=[];
  plans.forEach(p=>{
    const emp=STATE.employees.find(e=>e.id===p.employeeId);
    const updates=p.weeklyUpdates||[];
    const lastW=updates[updates.length-1];
    (p.actionItems||[]).forEach((item,i)=>{
      const lastStatus=lastW&&lastW.items?lastW.items.find(x=>x.idx===i):null;
      aiRows.push([emp?emp.name:'',p.type.toUpperCase(),i+1,item.area||'',item.text,lastStatus?lastStatus.status:'not reviewed',lastStatus?lastStatus.note||'':'']);
    });
  });
  if(aiRows.length>0)XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([aiHeader,...aiRows]),'Action Items');
  const meetingHeader=['Employee','Plan Type','Required?','Meeting Type','Due Date','Held Date','Status','Notes'];
  const meetingRows=[];
  plans.forEach(p=>{
    const emp=STATE.employees.find(e=>e.id===p.employeeId);
    getResolvedSchedule(p).forEach(m=>{
      meetingRows.push([emp?emp.name:'',p.type.toUpperCase(),'Yes',m.label||m.type,m.due,m.heldDate||'',m.status||'',m.notes||'']);
    });
    getManualMeetings(p).forEach(m=>{
      meetingRows.push([emp?emp.name:'',p.type.toUpperCase(),'No',m.label||m.type||'One-off meeting',m.dueDate||m.date||'',m.heldDate||m.date||'',m.status||'',m.notes||'']);
    });
  });
  if(meetingRows.length>0)XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet([meetingHeader,...meetingRows]),'Meeting Schedule');
  const summary=[['RISE Residential — Weekly Performance Report'],['Generated',new Date().toLocaleDateString()],[],['Region','Coaching','PIPs','Overdue','Missed Meetings','Incomplete Items']];
  Object.entries(REGIONS).forEach(([k,r])=>{
    const rPlans=plans.filter(p=>{const e=STATE.employees.find(x=>x.id===p.employeeId);return e&&e.region===k;});
    summary.push([r.name,rPlans.filter(p=>p.type==='coaching').length,rPlans.filter(p=>p.type==='pip').length,rPlans.filter(p=>daysLeft(p)<0).length,rPlans.reduce((a,p)=>a+getMissedMeetings(p),0),rPlans.reduce((a,p)=>a+getOverdueActionItems(p),0)]);
  });
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(summary),'Regional Summary');
  XLSX.writeFile(wb,`RISE_Weekly_Report_${new Date().toISOString().slice(0,10)}.xlsx`);
}

