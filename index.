function getSchedule(plan){
  if(!plan.presentedAt)return [];
  const start=new Date(`${plan.presentedAt}T12:00:00`);
  const end=new Date(`${plan.reviewDate}T12:00:00`);
  if(Number.isNaN(start.getTime())||Number.isNaN(end.getTime())||end<start)return [];
  const sched=[{schedIdx:0,weekLabel:'Day 1',type:'Initial presentation of PIP/Coaching plan',due:plan.presentedAt}];
  let idx=1;
  let week=1;
  const cursor=new Date(start);
  cursor.setDate(cursor.getDate()+7);
  while(cursor<end){
    sched.push({schedIdx:idx++,weekLabel:'Week '+week,type:'Weekly Follow Up',due:cursor.toISOString().slice(0,10)});
    cursor.setDate(cursor.getDate()+7);
    week++;
  }
  if(plan.reviewDate!==plan.presentedAt)sched.push({schedIdx:idx,weekLabel:'Final Review',type:'Task Completion Review',due:plan.reviewDate});
  return sched;
}

