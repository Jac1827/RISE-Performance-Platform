function confirmArchive(id){
  const p=STATE.plans.find(x=>x.id===id);
  if(!p)return;
  p.status='archived';
  p.archivedAt=new Date().toISOString().slice(0,10);
  p.archiveReason=document.getElementById('arch-reason').value;
  p.archiveNotes=document.getElementById('arch-notes').value;
  save();closeModal();renderView();
}

function unarchivePlan(id){
  const p=STATE.plans.find(x=>x.id===id);
  if(!p)return;
  const emp=STATE.employees.find(e=>e.id===p.employeeId);
  if(confirm('Restore this plan to Active status for '+(emp?emp.name:'this employee')+'?')){
    p.status='active';
    p.archivedAt=null;p.archiveReason=null;p.archiveNotes=null;
    save();renderView();
  }
}

function deletePlan(id){
  const p=STATE.plans.find(x=>x.id===id);
  if(!p)return;
  const emp=STATE.employees.find(e=>e.id===p.employeeId);
  const name=emp?emp.name:'this employee';
  const mc=document.getElementById('modal-container');
  mc.innerHTML=`<div class="modal-overlay" onclick="if(event.target===this)closeModal()">
