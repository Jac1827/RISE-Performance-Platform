function confirmDelete(id){
  const val=document.getElementById('del-confirm').value.trim();
  if(val!=='DELETE'){alert('Please type DELETE to confirm.');return;}
  STATE.plans=STATE.plans.filter(x=>x.id!==id);
  save();closeModal();renderView();
}

