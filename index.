function selectType(t){_selectedType=t;document.getElementById('type-coaching').className='chip'+(t==='coaching'?' selected':'');document.getElementById('type-pip').className='chip'+(t==='pip'?' selected':'');}
function selectCons(v){_selectedCons=v;document.getElementById('cons-yes').className='chip'+(v?' selected':'');document.getElementById('cons-no').className='chip'+(!v?' selected':'');}
function autoDetectType(){
  const s=parseFloat(document.getElementById('np-overall').value);
  const sug=document.getElementById('type-suggestion');if(isNaN(s)){sug.textContent='';return;}
  if(s<60){sug.innerHTML='<span style="color:#8B0000">Score below 60% — PIP recommended</span>';selectType('pip');}
  else if(s<84){sug.innerHTML='<span style="color:#5D4037">Below benchmark (84%) — Coaching plan recommended</span>';selectType('coaching');}
  else{sug.innerHTML='<span style="color:#27500A">Score meets benchmark</span>';}
}

