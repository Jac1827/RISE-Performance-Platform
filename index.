function addMeeting(planId){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan)return;
  if(!plan.meetings)plan.meetings=[];
  const type=getSelectedMeetingType('mt-type','mt-custom');
  const date=document.getElementById('mt-date').value;
  plan.meetings.push({
    label:type,
    type,
    dueDate:date,
    heldDate:date,
    date,
    status:document.getElementById('mt-status').value,
    notes:document.getElementById('mt-notes').value||''
  });
  save();renderView();
}

function removeMeeting(planId,meetingRef){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan||!plan.meetings)return;
  const ref=parseMeetingRef(meetingRef);
  let idx=-1;
  if(ref.kind==='manual')idx=ref.index;
  else if(ref.kind==='scheduled')idx=getMeetingArrayIndexBySchedIdx(plan,ref.index);
  if(idx>=0)plan.meetings.splice(idx,1);
  save();renderView();
}

function updateMeetingStatus(planId,meetingRef,status){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan||!plan.meetings)return;
  const ref=parseMeetingRef(meetingRef);
  let m=ref.kind==='manual'?plan.meetings[ref.index]:plan.meetings.find(x=>x.schedIdx===ref.index);
  if(!m&&ref.kind==='scheduled'){
    const sched=getSchedule(plan).find(s=>s.schedIdx===ref.index);
    if(!sched)return;
    m={schedIdx:ref.index,type:sched.type,label:sched.type,dueDate:sched.due,heldDate:'',date:sched.due,status,notes:''};
    plan.meetings.push(m);
  }
  if(m){m.status=status;save();renderView();}
}

function addActionItem(planId){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan)return;
  const text=document.getElementById('ai-text').value.trim();if(!text)return;
  if(!plan.actionItems)plan.actionItems=[];
  plan.actionItems.push({text,area:document.getElementById('ai-area').value.trim()});
  save();renderView();
}
function removeActionItem(planId,idx){
  const plan=STATE.plans.find(p=>p.id===planId);if(!plan||!plan.actionItems)return;
  plan.actionItems.splice(idx,1);save();renderView();
}

