function openTeaShopOrderEmail(plan){
  const emp=STATE.employees.find(e=>e.id===plan.employeeId);
  const employeeName=emp?emp.name:'Employee';
  const communityName=emp?emp.community||'Unknown community':'Unknown community';
  const subject=`Targeted shop order needed - ${employeeName}`;
  const body=[
    'Hi Tea,',
    '',
    'A targeted shop needs to be ordered for the following employee:',
    '',
    `Employee: ${employeeName}`,
    `Community: ${communityName}`,
    `Plan Type: ${(plan.type||'').toUpperCase()}`,
    `Plan Status: ${formatPlanStatus(plan.status)}`,
    '',
    'Please place the updated targeted shop order.',
    '',
    'Thank you,'
  ].join('\n');
  const link=document.createElement('a');
  link.href=`mailto:tea.jihad@risere.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
  link.click();
  plan.shopOrderEmailTriggeredAt=todayStr();
}
function markComplete(id){
  const p=STATE.plans.find(x=>x.id===id);
  if(!p)return;
  const needsUpdatedShop=!!p.requiresUpdatedShop;
  const confirmMsg=needsUpdatedShop
    ? 'Complete this plan and mark it as Shop Ordered? This will open a prefilled email to Tea to request the targeted shop.'
    : 'Mark this plan as completed?';
  if(!confirm(confirmMsg))return;
  p.completedAt=todayStr();
  if(needsUpdatedShop){
    p.status='shop_ordered';
    p.shopOrderedAt=todayStr();
    openTeaShopOrderEmail(p);
  }else{
    p.status='completed';
  }
  save();
  render();
}
function archivePlan(id){
  const p=STATE.plans.find(x=>x.id===id);
